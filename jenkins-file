pipeline {
    agent any
    
    environment {
        // הגדרת משתני סביבה לכל ה-Pipeline
        APP_ENV = "staging"
    }
    options{
        timeout(time:1, unit: 'MINUTES')
    }
    stages {
         stage('connect to github'){
        steps{
            withCredentials([
    		  usernamePassword(credentialsId: 'my_security_github', usernameVariable: 'USER', passwordVariable: 'PASS'),
    		]) {
    		  bat '''
    			echo  Deploying as %USER% %PASS%
    		  '''
    		}
        }
        }
        stage('Hello') {
            steps {
                sleep time: 15, unit:'SECONDS'
                // תיקון: שימוש בסוגריים מסולסלים עבור משתנה
                echo "build number: ${env.BUILD_NUMBER}"
                
                echo 'Hello World'
                
                // הדפסת משתנה הסביבה שהגדרנו למעלה
                echo "The environment is: ${APP_ENV}"
            }
        }

        stage('Shiri') {
            steps {
                echo 'Shirel'
            }
        }
    }
}
